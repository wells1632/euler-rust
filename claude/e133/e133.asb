10  REM PRIMES THAT NEVER DIVIDE R(10^N)
20  LET NS = 0
30  LET NC = 0
40  FOR P = 2 TO 99999
50  GOSUB 1000
60  IF IP = 0 THEN NEXT P
70  GOSUB 2000
80  IF CD = 0 THEN LET NC = NC + 1: LET NS = NS + P
90  NEXT P
100 PRINT "COUNT: ";NC
110 PRINT "SUM: ";NS
120 END
1000 REM --- PRIMALITY TEST, RETURNS IP ---
1010 LET IP = 0
1020 IF P < 2 THEN RETURN
1030 IF P = 2 THEN LET IP = 1: RETURN
1040 IF P = 3 THEN LET IP = 1: RETURN
1050 IF INT(P/2)*2 = P THEN RETURN
1060 IF INT(P/3)*3 = P THEN RETURN
1070 LET I = 5
1080 IF I*I > P THEN LET IP = 1: RETURN
1090 IF INT(P/I)*I = P THEN RETURN
1100 IF INT(P/(I+2))*(I+2) = P THEN RETURN
1110 LET I = I + 6
1120 GOTO 1080
2000 REM --- CAN P DIVIDE R(10^N)? RETURNS CD ---
2010 LET CD = 0
2020 IF P = 2 THEN RETURN
2030 IF P = 3 THEN RETURN
2040 IF P = 5 THEN RETURN
2050 GOSUB 3000
2060 GOSUB 4000
2070 IF SM = 1 THEN LET CD = 1
2080 RETURN
3000 REM --- MULTIPLICATIVE ORDER OF 10 MOD P, RETURNS OD ---
3010 LET OD = P - 1
3020 LET TN = P - 1
3030 LET TD = 2
3040 IF TD * TD > TN THEN GOTO 3100
3050 IF INT(TN/TD)*TD <> TN THEN LET TD = TD + 1: GOTO 3040
3060 REM TD IS A PRIME FACTOR OF P-1, TRY REDUCING OD
3070 IF INT(OD/TD)*TD <> OD THEN GOTO 3090
3080 LET TP = OD/TD: GOSUB 5000: IF MP = 1 THEN LET OD = TP: GOTO 3070
3090 LET TN = INT(TN/TD): GOTO 3040
3100 REM TN IS A REMAINING PRIME FACTOR
3110 IF TN <= 1 THEN RETURN
3120 IF INT(OD/TN)*TN <> OD THEN RETURN
3130 LET TP = OD/TN: GOSUB 5000: IF MP = 1 THEN LET OD = TP: GOTO 3120
3140 RETURN
4000 REM --- IS OD {2,5}-SMOOTH? RETURNS SM ---
4010 LET SM = 0
4020 LET SN = OD
4030 IF SN = 1 THEN LET SM = 1: RETURN
4040 IF INT(SN/2)*2 = SN THEN LET SN = INT(SN/2): GOTO 4030
4050 IF INT(SN/5)*5 = SN THEN LET SN = INT(SN/5): GOTO 4030
4060 RETURN
5000 REM --- MOD POW: 10^TP MOD P, RETURNS MP ---
5010 LET BS = 10
5020 LET EX = TP
5030 LET MD = P
5040 LET MP = 1
5050 LET BS = BS - INT(BS/MD)*MD
5060 IF EX <= 0 THEN RETURN
5070 IF INT(EX/2)*2 <> EX THEN LET MP = MP*BS - INT(MP*BS/MD)*MD
5080 LET EX = INT(EX/2)
5090 LET BS = BS*BS - INT(BS*BS/MD)*MD
5100 IF EX > 0 THEN GOTO 5070
5110 RETURN