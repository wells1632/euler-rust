10   REM FIND SUM OF FIRST 25 COMPOSITE N WHERE A(N) DIVIDES N-1
20   REM AND GCD(N,10)=1
30   CT = 0: SM = 0: N = 2
40   REM CHECK IF N IS COMPOSITE
50   GOSUB 2000
60   IF PR = 1 THEN GOTO 400
70   REM CHECK GCD(N,10)=1
80   GOSUB 1000
90   IF GC <> 1 THEN GOTO 400
100  REM FIND A(N) BY DIRECT ITERATION
110  GOSUB 3000
120  REM CHECK IF A(N) DIVIDES N-1
130  IF AN = 0 THEN GOTO 400
140  IF INT((N-1)/AN) <> (N-1)/AN THEN GOTO 400
150  REM FOUND ONE
160  CT = CT + 1
170  SM = SM + N
180  PRINT CT; ": N="; N; " A(N)="; AN
190  IF CT = 25 THEN GOTO 500
400  N = N + 1
410  GOTO 50
500  PRINT "SUM = "; SM
510  END
1000 REM GCD(N,10) SUBROUTINE - RESULT IN GC
1010 A = N: B = 10
1020 IF B = 0 THEN GC = A: RETURN
1030 T = B: B = A - INT(A/B)*B: A = T
1040 GOTO 1020
2000 REM PRIMALITY TEST - SETS PR=1 IF PRIME, PR=0 IF COMPOSITE
2010 PR = 0
2020 IF N < 2 THEN RETURN
2030 IF N = 2 THEN PR = 1: RETURN
2040 IF N = 3 THEN PR = 1: RETURN
2050 IF INT(N/2) = N/2 THEN RETURN
2060 IF INT(N/3) = N/3 THEN RETURN
2070 I = 5
2080 IF I*I > N THEN PR = 1: RETURN
2090 IF INT(N/I) = N/I THEN RETURN
2100 IF INT(N/(I+2)) = N/(I+2) THEN RETURN
2110 I = I + 6
2120 GOTO 2080
3000 REM FIND A(N) - LEAST K WHERE N DIVIDES R(K)
3010 REM R(K) = (R(K-1)*10+1) MOD N
3020 REM RESULT IN AN
3030 AN = 0: R = 0: K = 0
3040 R = R * 10 + 1
3050 IF R >= N THEN R = R - INT(R/N)*N
3060 K = K + 1
3070 IF R = 0 THEN AN = K: RETURN
3080 IF K > 1000000 THEN RETURN
3090 GOTO 3040